<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.9.0/fonts/remixicon.css" rel="stylesheet" />
    <link rel="stylesheet" href="style.css">
</head>

<body>
    <Main>
        <div class="page1">
            <div class="post-container">
                <div class="info-container">
                    <span class="profile-picName">
                        <span class="profile-pic-span">
                            <div class="profile-pic">
                                <img src="https://imgs.search.brave.com/OpbbSPZD14-aVE7MlUQDBUBAPlpS04udkFCBMt7jnDo/rs:fit:860:0:0:0/g:ce/aHR0cHM6Ly9tZWRp/YS5nZXR0eWltYWdl/cy5jb20vaWQvMjE5/MjIyMjExMi92ZWN0/b3IvcHJvZmlsZS1h/dmF0YXItb2YtYmVh/cmQtbWFuLXdlYXJp/bmctc3VuZ2xhc3Nl/cy5qcGc_cz02MTJ4/NjEyJnc9MCZrPTIw/JmM9ODJldmhBR0hK/VHJhNmtqbFdORHdk/b21xR3VtVWpKb3Fx/dUdKbWJZQ0M1QT0"
                                    alt="">
                            </div>
                        </span>

                        <div class="profile-name">
                            <span class="name">Rohit Saxena</span>
                            <span class="caption">Sugested for you.</span>
                        </div>
                    </span>
                    <span class="btnMore">
                        <div class="follow-btn">
                            <input type="submit" value="Follow">
                        </div>

                        <div class="more">
                            <i class="ri-more-2-line"></i>
                        </div>
                    </span>
                </div>
                <div class="post">
                    <img src="https://images.unsplash.com/photo-1541701494587-cb58502866ab?q=80&w=1170&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
                        alt="">
                </div>
                <div class="act-btn">
                    <span>
                        <span class="icon like">
                            <i class="ri-heart-line heart"></i>
                        </span>
                        <span class="icon comment">
                            <i class="ri-chat-1-line"></i>
                        </span>
                        <span class="icon repost">
                            <i class="ri-repeat-2-fill"></i>
                        </span>
                        <span class="icon share">
                            <i class="ri-share-forward-line"></i>
                        </span>
                    </span>

                    <span class="bookmark">
                        <i class="ri-bookmark-line"></i>
                    </span>

                </div>
            </div>
        </div>
    </Main>

    <script src="script.js"></script>
</body>

</html>
